{
  "dashboard": {
    "title": "SolidaryTech - SRE Dashboard (Golden Metrics & SLOs)",
    "uid": "solidarytech-sre",
    "timezone": "browser",
    "panels": [
      {
        "title": "SLO: Taxa de Sucesso - donation-service (Target: 99.9%)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "donation_service:http_requests:success_rate_5m * 100",
            "legendFormat": "Success Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 99.0},
                {"color": "yellow", "value": 99.5},
                {"color": "green", "value": 99.9}
              ]
            },
            "unit": "percent",
            "min": 95,
            "max": 100
          }
        }
      },
      {
        "title": "SLI: Latência P99 - donation-service (Target: < 500ms)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "donation_service:http_request_duration:p99_5m * 1000",
            "legendFormat": "P99 Latency (ms)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 300},
                {"color": "red", "value": 500}
              ]
            },
            "unit": "ms"
          }
        }
      },
      {
        "title": "Error Budget Restante - donation-service",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "donation_service:error_budget:remaining * 100",
            "legendFormat": "Error Budget %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 25},
                {"color": "green", "value": 50}
              ]
            }
          }
        }
      },
      {
        "title": "Golden Metrics - Request Rate (Traffic)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{service=\"donation-service\"}[5m]))",
            "legendFormat": "donation-service"
          },
          {
            "expr": "sum(rate(http_requests_total{service=\"ngo-service\"}[5m]))",
            "legendFormat": "ngo-service"
          },
          {
            "expr": "sum(rate(http_requests_total{service=\"volunteer-service\"}[5m]))",
            "legendFormat": "volunteer-service"
          }
        ]
      },
      {
        "title": "Golden Metrics - Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{service=\"donation-service\", code=~\"5..\"}[5m]))",
            "legendFormat": "donation-service 5xx"
          },
          {
            "expr": "sum(rate(http_requests_total{service=\"ngo-service\", code=~\"5..\"}[5m]))",
            "legendFormat": "ngo-service 5xx"
          }
        ]
      },
      {
        "title": "Golden Metrics - Latência P50/P95/P99",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"donation-service\"}[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"donation-service\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"donation-service\"}[5m])) by (le))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "title": "Saturation - CPU Usage por Serviço",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"solidarytech\"}[5m])) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ]
      }
    ],
    "tags": ["sre", "solidarytech", "slo"]
  }
}
